# ── 数据源 API Keys ──

# football-data.org (逗号分隔多个 Key, 每个 10次/分钟)
FOOTBALL_DATA_KEYS=key1,key2,key3

# OddsPapi (Pinnacle 赔率)
ODDSPAPI_KEY=your_oddspapi_key

# API-Football (Pro 计划, 7500次/天, 2017+赛季 + 赔率)
API_FOOTBALL_KEYS=your_key
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_KEY=


# ── 推送通知 (可选) ──

# Telegram Bot (去 @BotFather 创建机器人获取 token, 然后给机器人发消息获取 chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 通用 Webhook (飞书/钉钉/企业微信 — 填 URL 即可)
WEBHOOK_URL=

# 微信公众号 (预留)
WECHAT_APPID=
WECHAT_SECRET=

# ── Docker / Backend ──
ENVIRONMENT=production
DEBUG=false
POSTGRES_DB=football_quant
POSTGRES_USER=football
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://backend:8000
MLFLOW_TRACKING_URI=http://mlflow:5000
