# Build stage
FROM node:22-alpine AS builder

WORKDIR /app
COPY frontend-vue/package.json ./
RUN npm install
COPY frontend-vue/ .
RUN npm run build

# Nginx stage
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY docker/nginx.vue.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
